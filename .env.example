# ============================================================
# WiFiAIO Environment Configuration
# Copy this to .env and customize for your setup
# ============================================================

# ── General ──────────────────────────────────────────────────────
WIFAIO_INTERFACE=wlan0
WIFAIO_LOG_LEVEL=INFO
WIFAIO_OUTPUT_DIR=/tmp/wifiaio
WIFAIO_THEME=dark
WIFAIO_LANGUAGE=en

# ── API Server ──────────────────────────────────────────────────
WIFAIO_API_KEY=            # Set a strong API key for REST API access
WIFAIO_API_HOST=0.0.0.0
WIFAIO_API_PORT=8000

# ── Database ─────────────────────────────────────────────────────
WIFAIO_DB_PATH=/tmp/wifiaio/wifiaio.db

# ── Scanning ─────────────────────────────────────────────────────
WIFAIO_SCAN_TIMEOUT=30
WIFAIO_CHANNEL_HOP_DELAY=0.5

# ── Capture ──────────────────────────────────────────────────────
WIFAIO_CAPTURE_TIMEOUT=300
WIFAIO_CAPTURE_FORMAT=pcapng

# ── Cracking ─────────────────────────────────────────────────────
WIFAIO_WORDLIST=/usr/share/wordlists/rockyou.txt
WIFAIO_CRACKING_ENGINE=auto    # auto, hashcat, john
WIFAIO_MAX_THREADS=4

# ── OSINT ────────────────────────────────────────────────────────
WIGLE_API_KEY=             # Get from https://wigle.net/account
GOOGLE_GEO_API_KEY=        # Google Geolocation API key

# ── Notifications ────────────────────────────────────────────────
WIFAIO_NOTIFICATIONS=true
WIFAIO_WEBHOOK_URL=        # Optional webhook for alerts

# ── Updates ──────────────────────────────────────────────────────
WIFAIO_AUTO_CHECK_UPDATES=true

# ── Debug ────────────────────────────────────────────────────────
WIFAIO_DEBUG=false
